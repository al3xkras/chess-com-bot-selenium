# STOCKFISH_URL=https://github.com/official-stockfish/Stockfish/releases/download/sf_18/stockfish-windows-x86-64.zip
NUM_REPLICAS=1
REPLICA_PORTS=7910
CHROMIUM_SCREEN_WIDTH=1920
CHROMIUM_SCREEN_HEIGHT=1080
SELENIUM_NODE_IDLE_TIMEOUT_SECONDS=30
OPEN_BROWSER=True

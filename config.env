# local / docker
STARTUP_TYPE=docker
ELO_RATING=-1
GAME_TIMER_MS=150000
FIRST_MOVE_W=e2e4
AUTOSTART_FIRST_GAME=True
START_NEW_GAME_AUTOMATICALLY=True
# 1min / 1+1 / 2+1 / 3min / 3+2 / 5min / 10min / 15+10 / 30min / random_leq5min / random_leq10min
GAME_TYPE=random_leq5min
ENABLE_MOVE_DELAY=False
